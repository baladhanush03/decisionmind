# PostgreSQL Database configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=decisionmind

# Backend Configuration
SECRET_KEY=super_secret_key_change_in_production

# Frontend Configuration
# When building the frontend container, this URL will be baked into the static files.
# If you are hosting this on a specific domain or IP, change this to match (e.g. http://your-ip:8000/api/v1)
VITE_API_URL=http://localhost:8000/api/v1
